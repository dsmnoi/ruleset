{
  "dns": {
    "servers": [
      {
        "tag": "dns_proxy",
        "type": "https",
        "server": "1.1.1.1",
        "path": "/dns-query",
        "detour": "selectorMain"
      },
      {
        "tag": "dns_resolver",
        "type": "udp",
        "server": "223.5.5.5"
      }
    ],
    "rules": [
      {"rule_set": "geosite-cn", "server": "dns_resolver"},
      {"domain_suffix": [".cn", ".com.cn", ".net.cn"], "server": "dns_resolver"}
    ],
    "final": "dns_proxy",
    "strategy": "prefer_ipv4"
  },
  "inbounds": [{
    "type": "tun",
    "tag": "tun-in",
    "mtu": 1400,
    "auto_route": true,
    "strict_route": true,
    "stack": "mixed",
    "address": ["172.16.0.1/30", "fd00::1/126"]
  }],
  "outbounds": [
    {"tag": "selectorMain", "type": "selector", "outbounds": ["auto", "direct"], "default": "auto"},
    {"tag": "selectorOther", "type": "selector", "outbounds": ["auto", "direct", "selectorMain"], "default": "auto"},
    {"tag": "selectorAD", "type": "selector", "outbounds": ["direct", "block"], "default": "direct"},
    {"tag": "selectorPrivacy", "type": "selector", "outbounds": ["direct", "block"], "default": "direct"},
    {"tag": "auto", "type": "urltest", "outbounds": [], "url": "https://www.gstatic.com/generate_204"},
    {"tag": "direct", "type": "direct"},
    {"tag": "block", "type": "block"}
  ],
  "route": {
    "auto_detect_interface": true,
    "final": "selectorMain",
    "default_domain_resolver": "dns_resolver",
    "rule_set": [
      {"type": "remote", "format": "binary", "download_detour": "direct", "tag": "geosite-google", "url": "https://cdn.jsdmirror.com/gh/MetaCubeX/meta-rules-dat@sing/geo/geosite/google.srs"},
      {"type": "remote", "format": "binary", "download_detour": "direct", "tag": "geosite-youtube", "url": "https://cdn.jsdmirror.com/gh/MetaCubeX/meta-rules-dat@sing/geo/geosite/youtube.srs"},
      {"type": "remote", "format": "binary", "download_detour": "direct", "tag": "geosite-netflix", "url": "https://cdn.jsdmirror.com/gh/MetaCubeX/meta-rules-dat@sing/geo/geosite/netflix.srs"},
      {"type": "remote", "format": "binary", "download_detour": "direct", "tag": "geosite-telegram", "url": "https://cdn.jsdmirror.com/gh/MetaCubeX/meta-rules-dat@sing/geo/geosite/telegram.srs"},
      {"type": "remote", "format": "binary", "download_detour": "direct", "tag": "geoip-telegram", "url": "https://cdn.jsdmirror.com/gh/MetaCubeX/meta-rules-dat@sing/geo/geoip/telegram.srs"},
      {"type": "remote", "format": "binary", "download_detour": "direct", "tag": "geosite-openai", "url": "https://cdn.jsdmirror.com/gh/MetaCubeX/meta-rules-dat@sing/geo/geosite/openai.srs"},
      {"type": "remote", "format": "binary", "download_detour": "direct", "tag": "geosite-github", "url": "https://cdn.jsdmirror.com/gh/MetaCubeX/meta-rules-dat@sing/geo/geosite/github.srs"},
      {"type": "remote", "format": "binary", "download_detour": "direct", "tag": "geosite-cloudflare", "url": "https://cdn.jsdmirror.com/gh/MetaCubeX/meta-rules-dat@sing/geo/geosite/cloudflare.srs"},
      {"type": "remote", "format": "binary", "download_detour": "direct", "tag": "geosite-spotify", "url": "https://cdn.jsdmirror.com/gh/MetaCubeX/meta-rules-dat@sing/geo/geosite/spotify.srs"},
      {"type": "remote", "format": "binary", "download_detour": "direct", "tag": "geosite-category-ads-all", "url": "https://cdn.jsdmirror.com/gh/MetaCubeX/meta-rules-dat@sing/geo/geosite/category-ads-all.srs"},
      {"type": "remote", "format": "binary", "download_detour": "direct", "tag": "geoip-cn", "url": "https://cdn.jsdmirror.com/gh/MetaCubeX/meta-rules-dat@sing/geo/geoip/cn.srs"},
      {"type": "remote", "format": "binary", "download_detour": "direct", "tag": "geosite-cn", "url": "https://cdn.jsdmirror.com/gh/MetaCubeX/meta-rules-dat@sing/geo/geosite/cn.srs"},
      {"type": "remote", "format": "binary", "download_detour": "direct", "tag": "geosite-apple-cn", "url": "https://cdn.jsdmirror.com/gh/MetaCubeX/meta-rules-dat@sing/geo/geosite/apple@cn.srs"},
      {"type": "remote", "format": "binary", "download_detour": "direct", "tag": "geoip-private", "url": "https://cdn.jsdmirror.com/gh/MetaCubeX/meta-rules-dat@sing/geo/geoip/private.srs"}
    ],
    "rules": [
      {"action": "sniff", "override_destination": true},
      {"type": "logical", "mode": "or", "rules": [{"network": "udp", "port": 53}, {"protocol": "dns"}], "action": "hijack-dns"},
      {"rule_set": "geosite-category-ads-all", "outbound": "selectorAD"},
      {"rule_set": "geosite-google", "outbound": "selectorMain"},
      {"rule_set": "geosite-youtube", "outbound": "selectorMain"},
      {"rule_set": "geosite-netflix", "outbound": "selectorMain"},
      {"rule_set": ["geosite-telegram", "geoip-telegram"], "outbound": "selectorMain"},
      {"rule_set": "geosite-openai", "outbound": "selectorMain"},
      {"rule_set": "geosite-github", "outbound": "selectorMain"},
      {"rule_set": "geosite-cloudflare", "outbound": "selectorMain"},
      {"rule_set": "geosite-spotify", "outbound": "selectorMain"},
      {"rule_set": "geoip-private", "outbound": "direct"},
      {"rule_set": "geosite-apple-cn", "outbound": "direct"},
      {"rule_set": "geoip-cn", "outbound": "direct"},
      {"rule_set": "geosite-cn", "outbound": "direct"},
      {"domain_suffix": [".cn", ".com.cn", ".net.cn"], "outbound": "direct"}
    ]
  },
  "experimental": {"cache_file": {"enabled": true}}
}
